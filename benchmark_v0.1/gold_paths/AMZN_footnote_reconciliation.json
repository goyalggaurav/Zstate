    {
      "step": 4,
      "action": "Cross-check consolidated net sales",
      "tool": "Search_Filing",
      "target": "Consolidated Statements of Operations — Net sales 2025 column"
    },
    {
      "step": 5,
      "action": "Extract International FX growth disclosure",
      "tool": "Search_Filing",
