  "verification_policy": {
    "primary_anchor": "mdna_disclosed_organic_cc",
    "canonical_formula": "additive_percentage_points",
    "formula_definition": "organic_cc_pct = reported_growth_pct - fx_impact_pct (fx_impact signed per MD&A; headwind is negative)",
    "alternative_formulas": [
      {
        "id": "multiplicative",
        "definition": "((1 + reported_growth_pct/100) / (1 + fx_impact_pct/100) - 1) * 100",
        "example_europe_pct": 10.6,
        "tolerance_pp": 0.75,
        "layer1_treatment": "flag_METHOD_ALT — partial credit if inputs correct and MD&A cited; not strict L1 pass"
      },
      {
        "id": "wae_revenue_rebuild",
        "definition": "CC revenue at prior-year WAE, then YoY growth vs prior-year reported USD revenue",
        "tolerance_pp": 0.5,
        "layer1_treatment": "strict_pass_if_within_tolerance_and_wae_cited"
      }
    ],
    "tolerances": {
      "revenue_usd_millions": 0,
      "wae_fx_rate": 0.001,
      "reported_growth_pct": 0.1,
      "fx_impact_pct": 0.1,
      "organic_cc_pct_strict": 0.2,
      "organic_cc_pct_alternative_formula": 0.75
    },
    "hard_fail": [
