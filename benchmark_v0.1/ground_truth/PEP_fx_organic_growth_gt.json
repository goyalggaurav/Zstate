  "verification_policy": {
    "primary_anchor": "mdna_disclosed_organic_cc",
    "canonical_formula": "additive_percentage_points",
    "formula_definition": "organic_cc_pct = reported_growth_pct - fx_impact_pct (fx_impact signed per MD&A; favorable translation is positive)",
    "fx_rate_disclosure": {
      "wae_table_in_filing": false,
      "note": "FY2025 10-K does not publish weighted-average EUR/USD (or any currency-pair rate table). CC organic growth is verified via MD&A Net Revenue and Organic Revenue Performance — not WAE rebuild."
    },
    "alternative_formulas": [
      {
        "id": "multiplicative",
        "definition": "((1 + reported_growth_pct/100) / (1 + fx_impact_pct/100) - 1) * 100",
        "tolerance_pp": 0.75,
        "layer1_treatment": "flag_METHOD_ALT — partial credit if inputs correct and MD&A cited; not strict L1 pass"
      }
    ],
    "tolerances": {
      "revenue_usd_millions": 0,
      "reported_growth_pct": 0.1,
      "fx_impact_pct": 0.1,
      "organic_cc_pct_strict": 0.2,
      "organic_cc_pct_alternative_formula": 0.75
    },
