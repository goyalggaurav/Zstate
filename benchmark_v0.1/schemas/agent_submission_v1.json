{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "benchmark_v0.1/schemas/agent_submission_v1.json",
  "title": "Benchmark agent submission v1 (L1 metrics + L3 citations)",
  "description": "Wrapper around agent_output_v1 metrics. L1 verify scripts consume metrics only; L3 validator consumes full submission.",
  "type": "object",
  "required": ["schema_version", "metrics", "citations"],
  "properties": {
    "schema_version": { "const": "agent_submission_v1" },
    "metrics": {
      "description": "Flat L1 fields — must satisfy agent_output_v1.json for task type",
      "type": "object"
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/citation" }
    },
    "policy_acknowledgements": {
      "type": "array",
      "items": { "type": "string" },
      "description": "policy_id tokens from bundle policy_notes[]"
    }
  },
  "$defs": {
    "citation": {
      "type": "object",
      "required": ["metric_id", "doc_id", "section_slug", "snippet"],
      "properties": {
        "metric_id": { "type": "string" },
        "doc_id": {
          "type": "string",
          "description": "Must match task required_documents[].doc_id"
        },
        "section_slug": {
          "type": "string",
          "description": "Must match bundle section_registry[].section_slug"
        },
        "note": { "type": "string" },
        "table_title": { "type": "string" },
        "column": { "type": "string" },
        "snippet": {
          "type": "string",
          "description": "Verbatim substring from bundle excerpt for section_slug"
        }
      },
      "additionalProperties": false
    }
  }
}
