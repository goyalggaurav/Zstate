# Dual-control RL env — private expert artifacts (never commit)
env_v1/gold_keys/
**/gold_keys/*.json
!**/gold_keys.example/

# Track A — live eval outputs (regenerate: run_benchmark_campaign.py --execute)
benchmark_v0.1/runs/*
/runs/*
# Pinned scored campaign reports (reproducible leaderboard/brief without re-run)
!benchmark_v0.1/runs/pilot_eval_5task_v1/
benchmark_v0.1/runs/pilot_eval_5task_v1/*
!benchmark_v0.1/runs/pilot_eval_5task_v1/pilot_eval_5task_v1.json
# Synthetic L3 diagnostic report (LATER-05) — aggregate only; official pin unchanged
